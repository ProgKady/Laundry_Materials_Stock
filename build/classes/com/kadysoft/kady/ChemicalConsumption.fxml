<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXTextField?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Pane?>

<AnchorPane id="AnchorPane" prefHeight="908.0" prefWidth="1310.0" stylesheets="@../../../cascade/style/sheets/cupertino-light.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.kadysoft.kady.ChemicalConsumptionController">
   <children>
      <BorderPane layoutX="2.0" prefHeight="908.0" prefWidth="1310.0">
         <top>
            <MenuBar BorderPane.alignment="CENTER">
              <menus>
                <Menu mnemonicParsing="false" text="File">
                  <items>
                    <MenuItem fx:id="getallaudit" mnemonicParsing="false" onAction="#getallauditaction" text="Get All Consumption" />
                        <MenuItem mnemonicParsing="false" text="Font Size">
                           <graphic>
                              <Spinner fx:id="fontsize" editable="true" onKeyReleased="#fontsizerelaction" onMouseClicked="#fontsizeaction" />
                           </graphic>
                        </MenuItem>
                        <MenuItem fx:id="print" mnemonicParsing="false" onAction="#printaction" text="Print" />
                        <MenuItem fx:id="exporttoexcel" mnemonicParsing="false" onAction="#exporttoexcelaction" text="Export To Excel" />
                  </items>
                </Menu>
              </menus>
            </MenuBar>
         </top>
         <center>
            <Pane fx:id="pany" prefHeight="690.0" prefWidth="1310.0" BorderPane.alignment="CENTER">
               <children>
                  <TableView fx:id="datatable" layoutX="14.0" layoutY="14.0" prefHeight="780.0" prefWidth="1283.0" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-alignment: center;" tableMenuButtonVisible="true" />
                  <JFXTextField fx:id="con" alignment="CENTER" labelFloat="true" layoutX="43.0" layoutY="818.0" onMouseClicked="#conaction" prefHeight="32.0" prefWidth="227.0" promptText="Total Consumption" />
               </children>
            </Pane>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
