<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<BorderPane prefHeight="789.0" prefWidth="1307.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.kadysoft.kady.AMR_ChemicalConsumptionController">
   <top>
      <MenuBar style="-fx-font-weight: bold;" BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="File">
            <items>
              <MenuItem fx:id="getallaudit" mnemonicParsing="false" onAction="#getallauditaction" text="Get All Consumption" />
                  <MenuItem fx:id="consum" mnemonicParsing="false" onAction="#consumaction" text="Full Consumption Report" />
                  <MenuItem mnemonicParsing="false" text="Font Size">
                     <graphic>
                        <Spinner fx:id="fontsize" editable="true" onKeyReleased="#fontsizerelaction" onMouseClicked="#fontsizeaction" />
                     </graphic>
                  </MenuItem>
                  <MenuItem fx:id="print" mnemonicParsing="false" onAction="#printaction" text="Print" />
                  <MenuItem fx:id="exporttoexcel" mnemonicParsing="false" onAction="#exporttoexcelaction" text="Export To Excel" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>
   <center>
      <VBox fx:id="pany" prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="datatable" prefHeight="811.0" prefWidth="1307.0" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-alignment: center;" tableMenuButtonVisible="true" />
            <HBox alignment="CENTER_LEFT" prefHeight="0.0" prefWidth="1307.0" spacing="50.0">
               <children>
                  <VBox alignment="CENTER" prefHeight="46.0" prefWidth="271.0">
                     <children>
                        <Hyperlink fx:id="quaa" onMouseClicked="#quaaaction" prefHeight="23.0" prefWidth="193.0" style="-fx-font-weight: bold;" text="Click to get total quantities" />
                        <Hyperlink fx:id="quaa1" onMouseClicked="#quaa1action" style="-fx-font-weight: bold;" text="Click to get total quantities" visible="false" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="46.0" prefWidth="264.0">
                     <children>
                        <Hyperlink fx:id="con" alignment="CENTER" onMouseClicked="#conaction" prefHeight="28.0" prefWidth="265.0" style="-fx-font-weight: bold;" text="Click to get total consumption" />
                        <Hyperlink fx:id="con1" alignment="CENTER" onMouseClicked="#con1action" prefHeight="24.0" prefWidth="265.0" style="-fx-font-weight: bold;" text="Click to get total consumption" visible="false" />
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets left="20.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </center>
   <stylesheets>
      <URL value="@cupertino-light.css" />
      <URL value="@Styling.css" />
   </stylesheets>
</BorderPane>
