<AnchorPane id="AnchorPane" prefHeight="881.0" prefWidth="1696.0" stylesheets="@primer-dark.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.kadysoft.kady.Workers_MaterialsController">
   <children>
      <Pane layoutX="14.0" layoutY="797.0" prefHeight="79.0" prefWidth="1670.0">
