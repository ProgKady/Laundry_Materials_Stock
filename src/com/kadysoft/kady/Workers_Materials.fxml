                  <DropShadow />
               </effect>
            </JFXTextField>
            <JFXTextField fx:id="code" alignment="CENTER" labelFloat="true" layoutX="119.0" layoutY="22.0" onKeyReleased="#inputcode" prefHeight="36.0" prefWidth="90.0" promptText="Code" style="-fx-font-weight: bold;">
               <effect>
                  <DropShadow />
               </effect>
            </JFXTextField>
            <JFXTextField fx:id="name" alignment="CENTER" labelFloat="true" layoutX="213.0" layoutY="22.0" prefHeight="36.0" prefWidth="282.0" promptText="Name" style="-fx-font-weight: bold;">
